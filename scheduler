  /* ============================================================
     DESIGN TOKENS — refined neutral palette + intentional accents
     ============================================================ */
  :root {
    /* Neutrals — warm, considered scale */
    --bg: #fafaf9;
    --surface: #ffffff;
    --surface-2: #f7f7f5;
    --surface-3: #f0efeb;
    --border: #e8e7e3;
