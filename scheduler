    --danger: #b91c1c;
    --danger-bg: #fef2f2;
    --danger-border: #fecaca;

    /* Type scale */
    --text-xs: 11px;
    --text-sm: 13px;
    --text-base: 14px;
    --text-md: 15px;
    --text-lg: 18px;
    --text-xl: 22px;
    --text-2xl: 28px;
    --text-3xl: 34px;

    /* Refined shadows — layered, low-contrast */
