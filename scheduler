// ---------- Editor ----------
const Editor = ({ scheduleMeta, onBack }) => {
  const [schedule, setSchedule] = useState(scheduleMeta.data);
  const [editingTask, setEditingTask] = useState(null);
  const [isNewTask, setIsNewTask] = useState(false);
  const [showSettings, setShowSettings] = useState(false);
  const [saveStatus, setSaveStatus] = useState("idle");
  const [saveError, setSaveError] = useState(null);
  const fileInputRef = useRef(null);
  const debounceRef = useRef(null);
  const isFirstRender = useRef(true);

  const days = useMemo(() => buildWorkingDays(schedule.startDate, schedule.weeks), [schedule.startDate, schedule.weeks]);
  const numCols = days.length;

  const tasksByLane = useMemo(() => {
    const grouped = {};
    LANES.forEach((l) => (grouped[l.id] = []));
    schedule.tasks.forEach((t) => { if (grouped[t.lane]) grouped[t.lane].push(t); });
    return grouped;
  }, [schedule.tasks]);

  useEffect(() => {
    if (isFirstRender.current) { isFirstRender.current = false; return; }
    if (debounceRef.current) clearTimeout(debounceRef.current);
    setSaveStatus("saving");
    debounceRef.current = setTimeout(async () => {
      try {
        await upsertScheduleAPI(CONFIG.url, CONFIG.key, { id: scheduleMeta.id, name: scheduleMeta.name, data: schedule, updated_at: new Date().toISOString() });
        setSaveStatus("saved"); setSaveError(null);
        setTimeout(() => setSaveStatus("idle"), 1500);
      } catch (err) {
        setSaveStatus("error"); setSaveError(err.message);
      }
    }, 800);
    return () => { if (debounceRef.current) clearTimeout(debounceRef.current); };
  }, [schedule, scheduleMeta]);

  const handleAddTask = () => {
    setEditingTask({ id: `t${Date.now()}`, name: "New Task", lane: "project", startDay: 0, duration: 1, startTime: "", endTime: "", hours: null, note: "" });
    setIsNewTask(true);
  };
  const handleSaveTask = (task) => {
    setSchedule((prev) => {
      const exists = prev.tasks.find((t) => t.id === task.id);
      const tasks = exists ? prev.tasks.map((t) => (t.id === task.id ? task : t)) : [...prev.tasks, task];
      return { ...prev, tasks };
    });
    setEditingTask(null); setIsNewTask(false);
  };
  const handleDeleteTask = (id) => {
    setSchedule((prev) => ({ ...prev, tasks: prev.tasks.filter((t) => t.id !== id) }));
    setEditingTask(null);
  };
  const handleSaveJSON = () => {
    const blob = new Blob([JSON.stringify(schedule, null, 2)], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = `${scheduleMeta.name.replace(/[^a-z0-9]/gi, "_")}.json`; a.click();
    URL.revokeObjectURL(url);
  };
  const handleLoadJSON = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const loaded = JSON.parse(ev.target.result);
        if (!loaded.startDate || !loaded.weeks || !Array.isArray(loaded.tasks)) throw new Error("Invalid format");
        setSchedule(loaded);
      } catch (err) { alert("Failed: " + err.message); }
    };
    reader.readAsText(file);
    e.target.value = "";
  };
  const handleReload = async () => {
    try {
      const row = await loadScheduleAPI(CONFIG.url, CONFIG.key, scheduleMeta.id);
      isFirstRender.current = true;
      setSchedule(row.data);
      setSaveStatus("saved");
      setTimeout(() => setSaveStatus("idle"), 1500);
    } catch (err) { alert("Reload failed: " + err.message); }
  };

  const startDateObj = parseDate(schedule.startDate);
  const endDate = days.length ? days[days.length - 1] : startDateObj;

  const StatusBadge = () => {
    if (saveStatus === "saving") return <span className="inline-flex items-center gap-1 text-xs text-slate-500"><IconRefresh size={11} className="animate-spin" /> Saving...</span>;
    if (saveStatus === "saved") return <span className="inline-flex items-center gap-1 text-xs text-emerald-700"><IconCheck size={11} /> Saved</span>;
    if (saveStatus === "error") return <span className="inline-flex items-center gap-1 text-xs text-red-600" title={saveError}><IconAlert size={11} /> Save failed</span>;
    return <span className="text-xs text-slate-400">Synced</span>;
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900">
      <div className="max-w-[100rem] mx-auto px-6 py-8">
        <div className="flex items-end justify-between gap-4 mb-5 flex-wrap">
          <div>
            <div className="flex items-center gap-3 mb-2">
              <h1 className="text-2xl font-bold tracking-tight" style={{ fontWeight: 700 }}>{scheduleMeta.name}</h1>
              <StatusBadge />
            </div>
            <p className="text-sm text-slate-500" style={{ fontWeight: 450 }}>
              {monthName(startDateObj)} {startDateObj.getDate()} – {monthName(endDate)} {endDate.getDate()}, {endDate.getFullYear()} · {schedule.weeks}-week sprint · Mon–Fri only
            </p>
          </div>
          <div className="flex items-center gap-2 flex-wrap">
            {onBack && <button onClick={onBack} className="inline-flex items-center gap-1.5 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-300 text-slate-700 text-sm font-semibold rounded shadow-sm">← Schedules</button>}
            <button onClick={handleReload} className="inline-flex items-center gap-1.5 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-300 text-slate-700 text-sm font-semibold rounded shadow-sm" title="Pull latest"><IconRefresh /> Reload</button>
            <button onClick={handleAddTask} className="inline-flex items-center gap-1.5 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded shadow-sm"><IconPlus /> Add Task</button>
            <button onClick={() => setShowSettings(true)} className="inline-flex items-center gap-1.5 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-300 text-slate-700 text-sm font-semibold rounded shadow-sm"><IconCalendar /> Range</button>
            <button onClick={handleSaveJSON} className="inline-flex items-center gap-1.5 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-300 text-slate-700 text-sm font-semibold rounded shadow-sm" title="Backup as JSON"><IconDownload /></button>
            <button onClick={() => fileInputRef.current?.click()} className="inline-flex items-center gap-1.5 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-300 text-slate-700 text-sm font-semibold rounded shadow-sm" title="Import JSON"><IconUpload /></button>
            <input type="file" accept=".json" ref={fileInputRef} onChange={handleLoadJSON} className="hidden" />
          </div>
        </div>

        <div className="flex flex-wrap gap-2 bg-white p-2.5 border border-slate-200 rounded-lg shadow-sm mb-5">
          {LANES.map((l) => (
            <span key={l.id} className="inline-flex items-center gap-2 px-2.5 py-1 rounded text-xs font-medium text-slate-600">
              <span className="w-3 h-3 rounded-sm" style={{ backgroundColor: l.color }} />{l.name}
            </span>
          ))}
        </div>

        <div className="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden mb-5">
          <div className="flex items-center justify-between px-4 py-3 border-b border-slate-200 bg-slate-50">
            <div className="flex items-baseline gap-2">
              <span className="text-base font-bold tracking-tight">Project Schedule</span>
              <span className="text-xs text-slate-500">{numCols} working days · Click any task bar to edit</span>
            </div>
            <span className="text-[11px] font-semibold tracking-wide uppercase text-slate-500 bg-white border border-slate-200 px-2 py-1 rounded-full">Gantt View</span>
          </div>
          <div className="overflow-x-auto">
            <div style={{ display: "grid", gridTemplateColumns: `14rem repeat(${numCols}, minmax(5.5rem, 1fr))`, minWidth: `${14 + numCols * 5.5}rem` }}>
              <div className="bg-slate-50 border-r border-slate-200 border-b border-slate-300" />
              {days.map((d, i) => {
                const isFriday = d.getDay() === 5;
                const isLast = i === days.length - 1;
                return (
                  <div key={i} className="bg-white border-b border-slate-300 text-center py-2 px-1 flex flex-col items-center gap-0.5" style={{ borderRight: isLast ? "none" : isFriday ? "2px solid #d7dae4" : "1px solid #e6e8ef" }}>
                    <span className="text-[10px] font-semibold tracking-wider uppercase text-slate-400">{dayName(d)}</span>
                    <span className="text-sm font-bold text-slate-800">{d.getDate()}</span>
                    <span className="text-[10px] text-slate-500">{monthName(d)}</span>
                  </div>
                );
              })}
              {LANES.map((lane) => (
                <Fragment key={lane.id}>
                  <div className="px-3 py-3 border-r border-slate-200 border-b border-slate-200 bg-slate-50 flex flex-col gap-0.5 justify-center min-h-[3.75rem]">
                    <span className="text-xs font-semibold text-slate-800 inline-flex items-center gap-1.5">
                      <span className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: lane.color }} />{lane.name}
                    </span>
                    <span className="text-[10px] text-slate-500">{lane.desc}</span>
                  </div>
                  <div className="relative border-b border-slate-200 min-h-[3.75rem] bg-white" style={{ gridColumn: `2 / ${2 + numCols}`, display: "grid", gridTemplateColumns: `repeat(${numCols}, 1fr)` }}>
                    <div className="absolute inset-0 pointer-events-none opacity-70" style={{ backgroundImage: "linear-gradient(to right, #e6e8ef 1px, transparent 1px)", backgroundSize: `${100 / numCols}% 100%` }} />
                    {Array.from({ length: schedule.weeks - 1 }).map((_, wi) => (
                      <div key={wi} className="absolute top-0 bottom-0 w-0.5 bg-slate-300 pointer-events-none" style={{ left: `${((wi + 1) * 5 / numCols) * 100}%` }} />
                    ))}
                    {tasksByLane[lane.id].map((task) => {
                      if (task.startDay >= numCols) return null;

                      // Time-scale task: render proportional within its day column based on startTime/endTime
                      if (task.startTime && task.endTime) {
                        const sMin = timeToMin(task.startTime);
                        const eMin = timeToMin(task.endTime);
                        if (sMin == null || eMin == null || eMin <= sMin) return null;

                        const startFrac = (sMin - DAY_START_MIN) / DAY_TOTAL_MIN;
                        const widthFrac = (eMin - sMin) / DAY_TOTAL_MIN;
                        const dayWidth = 1 / numCols;

                        const leftPct = (task.startDay / numCols + startFrac * dayWidth) * 100;
                        const widthPct = widthFrac * dayWidth * 100;

                        return (
                          <button
                            key={task.id}
                            onClick={() => { setEditingTask(task); setIsNewTask(false); }}
                            className="absolute top-1/2 -translate-y-1/2 rounded text-xs font-semibold text-white shadow-sm hover:brightness-110 hover:shadow-md transition-all whitespace-nowrap overflow-hidden text-ellipsis text-left flex items-center gap-1"
                            style={{
                              left: `calc(${leftPct}% + 0.15%)`,
                              width: `calc(${widthPct}% - 0.3%)`,
                              height: "1.75rem",
                              padding: "0 6px",
                              backgroundColor: lane.color,
                              opacity: 0.92,
                              zIndex: 2,
                            }}
                            title={`${task.name} · ${formatTimeRange(task.startTime, task.endTime)}`}
                          >
                            <span className="overflow-hidden text-ellipsis">{task.name}</span>
                            <span className="opacity-80 font-normal text-[10px] shrink-0">· {formatTimeRange(task.startTime, task.endTime)}</span>
                          </button>
                        );
                      }

                      // Legacy hour-scale task (existing data with hours field but no startTime)
                      if (task.hours != null && task.hours > 0) {
                        const HOURS_PER_DAY = 10; // matches new 8 AM–6 PM window
                        const dayWidth = 1 / numCols;
                        const widthFrac = task.hours / HOURS_PER_DAY;
                        const leftPct = (task.startDay / numCols) * 100;
                        const widthPct = widthFrac * dayWidth * 100;
                        return (
                          <button
                            key={task.id}
                            onClick={() => { setEditingTask(task); setIsNewTask(false); }}
                            className="absolute top-1/2 -translate-y-1/2 rounded text-xs font-semibold text-white shadow-sm hover:brightness-110 hover:shadow-md transition-all whitespace-nowrap overflow-hidden text-ellipsis text-left flex items-center gap-1"
                            style={{
                              left: `calc(${leftPct}% + 0.15%)`,
                              width: `calc(${widthPct}% - 0.3%)`,
                              height: "1.75rem",
                              padding: "0 6px",
                              backgroundColor: lane.color,
                              opacity: 0.92,
                              zIndex: 2,
                            }}
                            title={`${task.name} · ${task.hours}h`}
                          >
                            <span className="overflow-hidden text-ellipsis">{task.name}</span>
                            <span className="opacity-80 font-normal text-[10px] shrink-0">· {task.hours}h</span>
                          </button>
                        );
                      }

                      // Day-scale task (full-day or multi-day)
                      const dur = Math.min(task.duration, numCols - task.startDay);
                      return (
                        <button key={task.id} onClick={() => { setEditingTask(task); setIsNewTask(false); }} className="absolute top-1/2 -translate-y-1/2 rounded px-2 py-1 text-xs font-semibold text-white shadow-sm hover:brightness-110 hover:shadow-md transition-all whitespace-nowrap overflow-hidden text-ellipsis text-left flex items-center gap-1.5" style={{ left: `calc(${(task.startDay / numCols) * 100}% + 0.2%)`, width: `calc(${(dur / numCols) * 100}% - 0.4%)`, height: "2.25rem", backgroundColor: lane.color, zIndex: 1 }} title="Click to edit">
                          <span className="overflow-hidden text-ellipsis">{task.name}</span>
                          {task.note && <span className="opacity-80 font-normal text-[10px]">· {task.note}</span>}
                        </button>
                      );
                    })}
                  </div>
                </Fragment>
              ))}
            </div>
          </div>
          <div className="px-4 py-3 border-t border-slate-200 bg-slate-50 flex flex-wrap gap-4 text-xs text-slate-600">
            <span><strong className="text-slate-800 font-semibold">{numCols}</strong> working days</span>
            <span><strong className="text-slate-800 font-semibold">{schedule.tasks.length}</strong> tasks</span>
            <span>Auto-saves to cloud · Reload pulls latest</span>
          </div>
        </div>

        <div className="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
          <div className="flex items-center justify-between px-4 py-3 border-b border-slate-200 bg-slate-50">
            <div className="flex items-baseline gap-2">
              <span className="text-base font-bold tracking-tight">Daily Hour-by-Hour Template</span>
              <span className="text-xs text-slate-500">8 AM – 5 PM · Fixed</span>
            </div>
          </div>
          <div className="p-5"><DailyTemplate /></div>
        </div>
      </div>

      {editingTask && <TaskModal task={editingTask} days={days} onSave={handleSaveTask} onDelete={handleDeleteTask} onClose={() => { setEditingTask(null); setIsNewTask(false); }} isNew={isNewTask} />}
      {showSettings && <SettingsModal schedule={schedule} onSave={(s) => { setSchedule((prev) => ({ ...prev, ...s })); setShowSettings(false); }} onClose={() => setShowSettings(false)} />}
    </div>
  );
};

