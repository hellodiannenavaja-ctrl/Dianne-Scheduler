const TaskModal = ({ task, days, onSave, onDelete, onClose, isNew }) => {
  const [form, setForm] = useState({
    name: task.name,
    lane: task.lane,
    startDay: task.startDay,
    duration: task.duration,
    startTime: task.startTime || "",
    endTime: task.endTime || "",
    note: task.note || "",
  });
  const handleSave = () => {
    if (!form.name.trim()) return alert("Task name required.");
    if (form.startDay < 0 || form.startDay >= days.length) return alert("Start day out of range.");

    const hasStart = !!form.startTime;
    const hasEnd = !!form.endTime;
    if (hasStart !== hasEnd) {
      return alert("Either set both Start Time and End Time, or leave both empty.");
    }

    let startTime = null;
    let endTime = null;
    if (hasStart && hasEnd) {
      const sMin = timeToMin(form.startTime);
      const eMin = timeToMin(form.endTime);
      if (sMin == null || eMin == null) return alert("Invalid time format.");
      if (eMin <= sMin) return alert("End Time must be after Start Time.");
      if (sMin < DAY_START_MIN || eMin > DAY_END_MIN) {
        return alert(`Times must be within 8:00 AM – 6:00 PM.`);
      }
      startTime = form.startTime;
      endTime = form.endTime;
    }

    if (!startTime) {
      // Day-scale: validate duration
      if (form.duration < 1 || form.startDay + form.duration > days.length) return alert("Duration extends beyond range.");
    }

    onSave({
      ...task,
      name: form.name,
      lane: form.lane,
      startDay: form.startDay,
      duration: form.duration,
      startTime,
      endTime,
      // Clear legacy hours field when saving via this UI
      hours: null,
      note: form.note,
    });
  };
  return (
    <div className="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
      <div className="bg-white rounded-lg shadow-xl w-full max-w-md">
        <div className="flex items-center justify-between px-5 py-4 border-b border-slate-200">
