const PickerScreen = ({ onPick, onForget }) => {
  const [schedules, setSchedules] = useState(null);
  const [error, setError] = useState(null);
  const [newName, setNewName] = useState("");

  const refresh = useCallback(async () => {
    setError(null);
    try { setSchedules(await listSchedulesAPI(CONFIG.url, CONFIG.key)); }
    catch (err) { setError(err.message); }
  }, []);

  useEffect(() => { refresh(); }, [refresh]);

  const handleCreate = async () => {
    if (!newName.trim()) return;
    const id = `sched_${Date.now()}`;
    try {
      await upsertScheduleAPI(CONFIG.url, CONFIG.key, { id, name: newName.trim(), data: initialSchedule, updated_at: new Date().toISOString() });
      onPick({ id, name: newName.trim(), data: initialSchedule });
    } catch (err) { setError(err.message); }
  };

  const handleLoad = async (id) => {
    try {
      const row = await loadScheduleAPI(CONFIG.url, CONFIG.key, id);
      onPick({ id: row.id, name: row.name, data: row.data });
    } catch (err) { setError(err.message); }
  };

  const handleDelete = async (id, name) => {
    if (!confirm(`Delete "${name}"? Cannot be undone.`)) return;
    try { await deleteScheduleAPI(CONFIG.url, CONFIG.key, id); refresh(); }
