// ---------- Export logic (XLSX via SheetJS) ----------

// Returns [start, end] Date objects (inclusive start, exclusive end) for the named range
const getRangeDates = (rangeName) => {
  const now = new Date();
  if (rangeName === "this_month") {
    const start = new Date(now.getFullYear(), now.getMonth(), 1);
    const end = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    return { start, end, label: `${monthName(start)} ${start.getFullYear()}` };
  }
  if (rangeName === "last_month") {
    const start = new Date(now.getFullYear(), now.getMonth() - 1, 1);
    const end = new Date(now.getFullYear(), now.getMonth(), 1);
    return { start, end, label: `${monthName(start)} ${start.getFullYear()}` };
  }
  // all_time
  return { start: null, end: null, label: "All Time" };
};

const inRange = (dateStr, start, end) => {
  if (!dateStr) return false; // exclude undated
  if (!start || !end) return true; // all_time
  const d = new Date(dateStr + "T00:00:00");
  return d >= start && d < end;
};

const buildExport = async (rangeName, scheduleData) => {
  if (typeof XLSX === "undefined") {
    throw new Error("XLSX library not loaded. Refresh the page and try again.");
  }
  const { start, end, label } = getRangeDates(rangeName);

  // Fetch fresh data for LPs and Blogs at export time
  const [lps, blogs] = await Promise.all([
    listLPsAPI(CONFIG.url, CONFIG.key),
    listBlogsAPI(CONFIG.url, CONFIG.key),
  ]);

  const wb = XLSX.utils.book_new();

  // ---- Sheet 1: Schedule ----
  // Per spec, always export full current schedule regardless of filter
  const days = buildWorkingDays(scheduleData.startDate, scheduleData.weeks);
  const scheduleRows = scheduleData.tasks.map((t) => {
    const isTimeScale = !!(t.startTime && t.endTime);
    const isHourScale = !isTimeScale && t.hours != null && t.hours > 0;
    const startDateObj = days[t.startDay] || null;
    // For sub-day tasks end date = start date
    const endDateObj = (isTimeScale || isHourScale)
      ? startDateObj
      : (days[Math.min(t.startDay + t.duration - 1, days.length - 1)] || null);
    const laneName = (LANES.find((l) => l.id === t.lane) || {}).name || t.lane;
    return {
      "Task Name": t.name,
      "Lane": laneName,
      "Start Date": startDateObj ? startDateObj.toISOString().slice(0, 10) : "",
      "End Date": endDateObj ? endDateObj.toISOString().slice(0, 10) : "",
      "Start Time": isTimeScale ? formatTime12(t.startTime) : "",
      "End Time": isTimeScale ? formatTime12(t.endTime) : "",
      "Duration (days)": (isTimeScale || isHourScale) ? "" : t.duration,
      "Hours": isHourScale ? t.hours : (isTimeScale ? ((timeToMin(t.endTime) - timeToMin(t.startTime)) / 60) : ""),
      "Note": t.note || "",
    };
  });
  // Add a header summary row
  const scheduleMeta = [
    [`Schedule: ${scheduleData.startDate} · ${scheduleData.weeks} week(s) · ${days.length} working days`],
    [],
  ];
  const wsSchedule = XLSX.utils.aoa_to_sheet(scheduleMeta);
  XLSX.utils.sheet_add_json(wsSchedule, scheduleRows, { origin: "A3" });
  wsSchedule["!cols"] = [{ wch: 36 }, { wch: 22 }, { wch: 12 }, { wch: 12 }, { wch: 11 }, { wch: 11 }, { wch: 14 }, { wch: 8 }, { wch: 28 }];
  XLSX.utils.book_append_sheet(wb, wsSchedule, "Schedule");

  // ---- Sheet 2: Landing Pages ----
  const lpFiltered = lps.filter((lp) => inRange(lp.date_launched, start, end));
  const lpRows = lpFiltered.map((lp) => ({
    "Name": lp.name || "",
    "URL": lp.url || "",
    "Status": lp.status || "",
    "Category": lp.category || "",
    "Brand": lp.brand || "",
    "Date Launched": lp.date_launched || "",
    "Notes": lp.notes || "",
  }));
  const lpMeta = [
    [`Landing Pages · ${label} · ${lpFiltered.length} item(s) shipped`],
    [],
  ];
  const wsLP = XLSX.utils.aoa_to_sheet(lpMeta);
  if (lpRows.length > 0) {
    XLSX.utils.sheet_add_json(wsLP, lpRows, { origin: "A3" });
  } else {
    XLSX.utils.sheet_add_aoa(wsLP, [["No landing pages shipped in this range."]], { origin: "A3" });
  }
  wsLP["!cols"] = [{ wch: 30 }, { wch: 40 }, { wch: 14 }, { wch: 18 }, { wch: 14 }, { wch: 14 }, { wch: 36 }];
  XLSX.utils.book_append_sheet(wb, wsLP, "Landing Pages");

  // ---- Sheet 3: Blogs ----
  const blogFiltered = blogs.filter((b) => inRange(b.publish_date, start, end));
  const blogRows = blogFiltered.map((b) => ({
    "Title": b.title || "",
    "URL": b.url || "",
    "Status": b.status || "",
    "Brand": b.brand || "",
    "Category": b.category || "",
    "Publish Date": b.publish_date || "",
    "Notes": b.notes || "",
  }));
  const blogMeta = [
    [`Blogs · ${label} · ${blogFiltered.length} item(s) published`],
    [],
  ];
  const wsBlog = XLSX.utils.aoa_to_sheet(blogMeta);
  if (blogRows.length > 0) {
    XLSX.utils.sheet_add_json(wsBlog, blogRows, { origin: "A3" });
  } else {
    XLSX.utils.sheet_add_aoa(wsBlog, [["No blogs published in this range."]], { origin: "A3" });
  }
  wsBlog["!cols"] = [{ wch: 36 }, { wch: 40 }, { wch: 14 }, { wch: 14 }, { wch: 22 }, { wch: 14 }, { wch: 36 }];
  XLSX.utils.book_append_sheet(wb, wsBlog, "Blogs");

  // Filename
  const today = new Date().toISOString().slice(0, 10);
  let fileLabel;
  if (rangeName === "all_time") fileLabel = "all-time";
  else fileLabel = `${start.getFullYear()}-${String(start.getMonth() + 1).padStart(2, "0")}`;
  const filename = `marketing-export_${fileLabel}_${today}.xlsx`;

  XLSX.writeFile(wb, filename);
  return { lpCount: lpFiltered.length, blogCount: blogFiltered.length, label };
};

// ---------- Export Button ----------
const IconDownloadCloud = (p) => <Icon {...p} d={<><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></>} />;

const ExportButton = ({ scheduleData }) => {
  const [open, setOpen] = useState(false);
  const [busy, setBusy] = useState(false);
  const [error, setError] = useState(null);
  const [success, setSuccess] = useState(null);
  const containerRef = useRef(null);

  // Close popover when clicking outside
  useEffect(() => {
    if (!open) return;
    const handler = (e) => {
      if (containerRef.current && !containerRef.current.contains(e.target)) {
        setOpen(false);
      }
    };
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, [open]);

  const doExport = async (rangeName) => {
    setBusy(true);
    setError(null);
    setSuccess(null);
    try {
      const result = await buildExport(rangeName, scheduleData);
      setSuccess(`Exported ${result.label}: ${result.lpCount} LP(s), ${result.blogCount} blog(s).`);
      setTimeout(() => setSuccess(null), 4000);
      setTimeout(() => setOpen(false), 600);
    } catch (err) {
      setError(err.message);
    } finally {
      setBusy(false);
    }
  };

  return (
    <div className="relative" ref={containerRef}>
      <button
        onClick={() => setOpen(!open)}
        className="inline-flex items-center gap-1.5 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-300 text-slate-700 text-sm font-semibold rounded shadow-sm"
      >
        <IconDownloadCloud /> Export
      </button>
      {open && (
        <div className="absolute right-0 top-full mt-2 w-72 bg-white border border-slate-200 rounded-lg shadow-lg z-30 p-3">
          <div className="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2 px-1">Download as XLSX</div>
          <div className="flex flex-col gap-1">
            <button onClick={() => doExport("this_month")} disabled={busy} className="text-left px-3 py-2 rounded text-sm font-medium hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed">
              <span className="block text-slate-800">This month</span>
              <span className="block text-[11px] text-slate-500">{getRangeDates("this_month").label}</span>
            </button>
            <button onClick={() => doExport("last_month")} disabled={busy} className="text-left px-3 py-2 rounded text-sm font-medium hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed">
              <span className="block text-slate-800">Last month</span>
              <span className="block text-[11px] text-slate-500">{getRangeDates("last_month").label}</span>
            </button>
            <button onClick={() => doExport("all_time")} disabled={busy} className="text-left px-3 py-2 rounded text-sm font-medium hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed">
              <span className="block text-slate-800">All time</span>
              <span className="block text-[11px] text-slate-500">Everything with a date</span>
            </button>
          </div>
          {busy && (
            <div className="mt-2 px-3 py-2 bg-blue-50 border border-blue-200 rounded text-xs text-blue-800 inline-flex items-center gap-1.5">
              <IconRefresh size={12} className="animate-spin" /> Building file...
            </div>
          )}
          {success && (
            <div className="mt-2 px-3 py-2 bg-emerald-50 border border-emerald-200 rounded text-xs text-emerald-800 inline-flex items-start gap-1.5">
              <IconCheck size={12} className="mt-0.5 shrink-0" /><span>{success}</span>
            </div>
          )}
          {error && (
            <div className="mt-2 px-3 py-2 bg-red-50 border border-red-200 rounded text-xs text-red-800 flex items-start gap-1.5">
              <IconAlert size={12} className="mt-0.5 shrink-0" /><span>{error}</span>
            </div>
          )}
          <div className="mt-2 pt-2 border-t border-slate-100 text-[10px] text-slate-400 px-1">
            Schedule sheet always shows current state. LP & Blog sheets filtered by launch/publish date in selected range.
          </div>
        </div>
      )}
    </div>
  );
};

// ---------- App root ----------
const SINGLE_SCHEDULE_ID = "my_schedule";
const SINGLE_SCHEDULE_NAME = "My Schedule";

const TabBar = ({ activeTab, onChange }) => (
  <div className="bg-white border border-slate-200 rounded-lg shadow-sm inline-flex p-1 gap-0.5" style={{ padding: "5px" }}>
    {[
      { id: "schedule", label: "Schedule" },
      { id: "landing_pages", label: "Landing Pages" },
      { id: "blogs", label: "Blogs" },
    ].map((tab) => {
      const active = activeTab === tab.id;
      return (
        <button
          key={tab.id}
          onClick={() => onChange(tab.id)}
          className={`text-sm rounded ${
            active
              ? "bg-slate-900 text-white"
              : "text-slate-600 hover:bg-slate-100"
          }`}
          style={{
            padding: "8px 16px",
            fontWeight: active ? 600 : 500,
            letterSpacing: "-0.005em",
          }}
        >
          {tab.label}
        </button>
      );
    })}
  </div>
);

const Workspace = ({ scheduleMeta }) => {
  const [activeTab, setActiveTab] = useState(() => {
    const saved = ls.get("active_tab");
    const v = saved?.value;
    if (v === "landing_pages" || v === "blogs") return v;
    return "schedule";
  });

  const handleTabChange = (id) => {
    setActiveTab(id);
    ls.set("active_tab", id);
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900">
      <div className="max-w-[100rem] mx-auto px-6" style={{ paddingTop: "32px" }}>
        <div className="flex items-center justify-between gap-3 flex-wrap" style={{ marginBottom: "24px" }}>
          <TabBar activeTab={activeTab} onChange={handleTabChange} />
          <ExportButton scheduleData={scheduleMeta.data} />
        </div>
      </div>
      {activeTab === "schedule" && <Editor scheduleMeta={scheduleMeta} onBack={null} />}
      {activeTab === "landing_pages" && (
        <div className="max-w-[100rem] mx-auto px-6 pb-8 pt-2">
          <LandingPagesView />
        </div>
      )}
      {activeTab === "blogs" && (
        <div className="max-w-[100rem] mx-auto px-6 pb-8 pt-2">
          <BlogsView />
        </div>
      )}
    </div>
  );
};

const App = () => {
  const [pickedSchedule, setPickedSchedule] = useState(null);
  const [bootState, setBootState] = useState("loading");
  const [bootError, setBootError] = useState(null);

  useEffect(() => {
    (async () => {
      try {
        let row = await loadScheduleAPI(CONFIG.url, CONFIG.key, SINGLE_SCHEDULE_ID);
        if (!row) {
          const created = await upsertScheduleAPI(CONFIG.url, CONFIG.key, {
            id: SINGLE_SCHEDULE_ID,
            name: SINGLE_SCHEDULE_NAME,
            data: initialSchedule,
            updated_at: new Date().toISOString(),
          });
          row = Array.isArray(created) ? created[0] : created;
        }
        setPickedSchedule({ id: row.id, name: row.name, data: row.data });
        setBootState("ready");
      } catch (err) {
        setBootError(err.message);
        setBootState("error");
      }
    })();
  }, []);

  if (bootState === "loading") {
    return (
      <div className="min-h-screen bg-slate-50 flex items-center justify-center text-sm text-slate-500">
        <div className="inline-flex items-center gap-2"><IconRefresh size={14} className="animate-spin" /> Loading your schedule...</div>
      </div>
    );
  }

  if (bootState === "error") {
    return (
      <div className="min-h-screen bg-slate-50 flex items-center justify-center p-6">
        <div className="max-w-md bg-white border border-slate-200 rounded-lg shadow-sm p-6">
          <div className="flex items-start gap-2 text-red-700 mb-3">
            <IconAlert size={18} className="mt-0.5 shrink-0" />
            <h2 className="text-base font-semibold">Failed to load schedule</h2>
          </div>
          <p className="text-sm text-slate-600 mb-3">The app couldn't reach Supabase. Try refreshing the page.</p>
          <p className="text-xs text-slate-500 font-mono bg-slate-50 p-2 rounded border border-slate-200 break-all">{bootError}</p>
          <button onClick={() => window.location.reload()} className="mt-4 inline-flex items-center gap-1.5 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded">
            <IconRefresh /> Retry
          </button>
        </div>
      </div>
    );
  }

  return <Workspace scheduleMeta={pickedSchedule} />;
};

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
