const buildWorkingDays = (startDateStr, weeks) => {
  const start = parseDate(startDateStr);
  const dow = start.getDay();
  let mondayStart = start;
  if (dow !== 1) {
    const offset = dow === 0 ? 1 : 1 - dow;
    mondayStart = addDays(start, offset);
  }
  const days = [];
  for (let w = 0; w < weeks; w++) {
    for (let d = 0; d < 5; d++) days.push(addDays(mondayStart, w * 7 + d));
  }
  return days;
};

