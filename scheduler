// ---------- Landing Pages view ----------
const LandingPagesView = () => {
  const [lps, setLps] = useState(null);
  const [error, setError] = useState(null);
  const [editingLP, setEditingLP] = useState(null);
  const [isNewLP, setIsNewLP] = useState(false);
  const [filterStatus, setFilterStatus] = useState("all");
  const [filterCategory, setFilterCategory] = useState("all");
  const [filterBrand, setFilterBrand] = useState("all");

  const refresh = useCallback(async () => {
    setError(null);
    try { setLps(await listLPsAPI(CONFIG.url, CONFIG.key)); }
    catch (err) { setError(err.message); }
  }, []);

  useEffect(() => { refresh(); }, [refresh]);

  const handleAdd = () => {
    setEditingLP({ id: `lp_${Date.now()}`, name: "", url: "", status: "In Progress", category: "Campaign", brand: "", date_launched: "", notes: "" });
    setIsNewLP(true);
  };

  const handleSave = async (lp) => {
    try {
      const row = {
        ...lp,
        updated_at: new Date().toISOString(),
      };
      await upsertLPAPI(CONFIG.url, CONFIG.key, row);
      setEditingLP(null); setIsNewLP(false);
      refresh();
    } catch (err) { alert("Save failed: " + err.message); }
  };

  const handleDelete = async (id) => {
    try {
      await deleteLPAPI(CONFIG.url, CONFIG.key, id);
      setEditingLP(null);
      refresh();
    } catch (err) { alert("Delete failed: " + err.message); }
  };

  const filtered = useMemo(() => {
    if (!lps) return null;
    return lps.filter((lp) => {
      if (filterStatus !== "all" && lp.status !== filterStatus) return false;
      if (filterCategory !== "all" && lp.category !== filterCategory) return false;
      if (filterBrand !== "all") {
        if (filterBrand === "none" && lp.brand) return false;
        if (filterBrand !== "none" && lp.brand !== filterBrand) return false;
      }
      return true;
    });
  }, [lps, filterStatus, filterCategory, filterBrand]);

  const statusInfo = (statusId) => LP_STATUSES.find((s) => s.id === statusId) || LP_STATUSES[2];

  // Counts for the summary footer
  const counts = useMemo(() => {
    if (!lps) return { total: 0, live: 0, inProgress: 0, forReview: 0, draft: 0, archived: 0 };
    return {
      total: lps.length,
      live: lps.filter((l) => l.status === "Live").length,
      inProgress: lps.filter((l) => l.status === "In Progress").length,
      forReview: lps.filter((l) => l.status === "For Review").length,
      draft: lps.filter((l) => l.status === "Draft").length,
      archived: lps.filter((l) => l.status === "Archived").length,
    };
  }, [lps]);

  return (
    <div className="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
      <div className="flex items-center justify-between px-4 py-3 border-b border-slate-200 bg-slate-50 flex-wrap gap-2">
        <div className="flex items-baseline gap-2">
          <span className="text-base font-bold tracking-tight">Landing Pages</span>
          <span className="text-xs text-slate-500">All shipped & in-progress LPs · Click row to edit</span>
        </div>
        <div className="flex items-center gap-2 flex-wrap">
          <select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className="px-2 py-1.5 border border-slate-300 rounded text-xs focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="all">All statuses</option>
            {LP_STATUSES.map((s) => <option key={s.id} value={s.id}>{s.id}</option>)}
          </select>
          <select value={filterCategory} onChange={(e) => setFilterCategory(e.target.value)} className="px-2 py-1.5 border border-slate-300 rounded text-xs focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="all">All categories</option>
            {LP_CATEGORIES.map((c) => <option key={c} value={c}>{c}</option>)}
          </select>
          <select value={filterBrand} onChange={(e) => setFilterBrand(e.target.value)} className="px-2 py-1.5 border border-slate-300 rounded text-xs focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="all">All brands</option>
            {LP_BRANDS.map((b) => <option key={b} value={b}>{b}</option>)}
            <option value="none">— No brand —</option>
          </select>
          <button onClick={refresh} className="p-1.5 text-slate-600 hover:bg-slate-100 rounded border border-slate-300" title="Refresh"><IconRefresh /></button>
          <button onClick={handleAdd} className="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded">
            <IconPlus /> Add Landing Page
          </button>
        </div>
